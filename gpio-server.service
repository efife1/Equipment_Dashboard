[Unit]
Description=ESP32 GPIO Monitor Server
After=network-online.target mosquitto.service
Wants=network-online.target
Requires=mosquitto.service

[Service]
Type=simple
User=__INSTALL_USER__
WorkingDirectory=/opt/gpio-monitor
ExecStart=/opt/gpio-monitor/venv/bin/python3 /opt/gpio-monitor/gpio_server.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
